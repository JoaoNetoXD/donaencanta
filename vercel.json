{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/_next/:path*", "destination": "https://serverflow.dad/_next/:path*" },
    { "source": "/pwa/:path*", "destination": "https://serverflow.dad/pwa/:path*" }
  ]
}
